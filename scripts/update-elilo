#!/bin/sh
# update-elilo — copy the latest kernel/initrd to the ESP and regenerate elilo.conf
#
# Called automatically by /etc/kernel/postinst.d/zz-update-elilo after each
# kernel install, and by /etc/kernel/postrm.d/zz-update-elilo after removal.
# May also be run manually: sudo update-elilo [version]
#
# Config: /etc/elilo/update.conf
#
# Usage:
#   update-elilo <kernel-version>   — install/update a specific kernel
#   update-elilo                    — refresh config using newest kernel in /boot

set -e

CONFIG=/etc/elilo/update.conf

# Load user config
[ -f "$CONFIG" ] && . "$CONFIG"

# Defaults — all may be overridden in update.conf
ELILO_DIR="${ELILO_DIR:-/boot/efi/EFI/elilo}"
ELILO_CONF="${ELILO_CONF:-$ELILO_DIR/elilo.conf}"
ROOT_DEV="${ROOT_DEV:-}"
APPEND="${APPEND:-ro quiet}"
KEEP_PREVIOUS="${KEEP_PREVIOUS:-1}"
TIMEOUT="${TIMEOUT:-50}"
PROMPT="${PROMPT:-1}"

# ── Version-aware kernel listing helper ─────────────────────────────────────
# kernel_versions DIR
#   Print the version suffix of every vmlinuz-* in DIR, one per line, sorted
#   highest version first. Operates only on the suffix after "vmlinuz-", so
#   version metacharacters (+ ~ - +debNN) sort correctly. Prefers Debian's
#   linux-version (from linux-base); falls back to GNU sort -V.
kernel_versions() {
    dir=$1
    for img in "$dir"/vmlinuz-*; do
        [ -e "$img" ] || continue
        base=${img##*/}
        printf '%s\n' "${base#vmlinuz-}"
    done | {
        if command -v linux-version >/dev/null 2>&1; then
            linux-version sort --reverse
        else
            sort -V -r
        fi
    }
}

# ── Determine kernel version ────────────────────────────────────────────────

if [ -n "$1" ]; then
    # Explicit version from the postinst hook (or manual invocation).
    NEW_VERSION="$1"
else
    # Highest installed kernel VERSION in /boot (not newest mtime).
    NEW_VERSION=$(kernel_versions /boot | head -1)
fi

if [ -z "$NEW_VERSION" ]; then
    echo "update-elilo: no kernel found in /boot" >&2
    exit 0
fi

# ── Check ESP is mounted ─────────────────────────────────────────────────────

ESP_ROOT=$(echo "$ELILO_DIR" | sed 's|/EFI/.*||')
if ! mountpoint -q "$ESP_ROOT" 2>/dev/null; then
    echo "update-elilo: ESP not mounted at $ESP_ROOT, skipping" >&2
    exit 0
fi

if [ ! -d "$ELILO_DIR" ]; then
    echo "update-elilo: elilo directory $ELILO_DIR does not exist" >&2
    echo "  Create it and install elilo.efi first, then run update-elilo again." >&2
    exit 1
fi

# ── Copy kernel and initrd to ESP ────────────────────────────────────────────

# Fail loud if the requested/selected kernel image does not exist — do NOT
# proceed to overwrite a working elilo.conf with a broken one.
if [ ! -f "/boot/vmlinuz-$NEW_VERSION" ]; then
    echo "update-elilo: ERROR: /boot/vmlinuz-$NEW_VERSION does not exist" >&2
    echo "  Refusing to regenerate $ELILO_CONF. No changes made." >&2
    exit 1
fi

install -m 644 "/boot/vmlinuz-$NEW_VERSION" "$ELILO_DIR/vmlinuz-$NEW_VERSION"
echo "update-elilo: copied vmlinuz-$NEW_VERSION to $ELILO_DIR"

# Locate the matching initrd. The standard Debian path is
# /boot/initrd.img-$VERSION; probe a couple of common variants too.
NEW_INITRD=""
for cand in \
    "/boot/initrd.img-$NEW_VERSION" \
    "/boot/initrd-$NEW_VERSION.img" \
    "/boot/initramfs-$NEW_VERSION.img"; do
    if [ -f "$cand" ]; then
        NEW_INITRD="$cand"
        break
    fi
done

if [ -n "$NEW_INITRD" ]; then
    install -m 644 "$NEW_INITRD" "$ELILO_DIR/initrd.img-$NEW_VERSION"
    echo "update-elilo: copied $(basename "$NEW_INITRD") to $ELILO_DIR/initrd.img-$NEW_VERSION"
else
    echo "update-elilo: WARNING: no initrd found for $NEW_VERSION in /boot" >&2
    echo "  A normal Devuan/Debian system will NOT boot without an initrd." >&2
    echo "  Run: update-initramfs -c -k $NEW_VERSION, then re-run update-elilo." >&2
fi

# ── Find previous kernel on ESP (for fallback entry) ─────────────────────────

PREV_VERSION=""
if [ "$KEEP_PREVIOUS" = "1" ]; then
    # Highest installed VERSION on the ESP that is not the new one.
    PREV_VERSION=$(kernel_versions "$ELILO_DIR" \
        | grep -Fxv "$NEW_VERSION" \
        | head -1)
fi

# ── Determine EFI path prefix for elilo.conf ─────────────────────────────────
# elilo.conf image= paths are relative to the ESP root, e.g. /EFI/elilo/vmlinuz-X

EFI_PATH=$(echo "$ELILO_DIR" | sed "s|$ESP_ROOT||")

# ── Auto-detect root device if not configured ────────────────────────────────

if [ -z "$ROOT_DEV" ]; then
    ROOT_DEV=$(findmnt -n -o SOURCE / 2>/dev/null | head -1)
    if [ -z "$ROOT_DEV" ]; then
        echo "update-elilo: could not detect root device; set ROOT_DEV in $CONFIG" >&2
        exit 1
    fi
fi

# ── Generate elilo.conf atomically ───────────────────────────────────────────

CONF_TMP="${ELILO_CONF}.tmp.$$"
trap 'rm -f "$CONF_TMP"' EXIT INT TERM

{
    echo "# Generated by update-elilo -- edit /etc/elilo/update.conf, not this file"
    [ "$PROMPT" = "1" ] && echo "prompt"
    echo "timeout=$TIMEOUT"
    echo "default=linux"
    echo ""
    echo "image=$EFI_PATH/vmlinuz-$NEW_VERSION"
    echo "  label=linux"
    if [ -f "$ELILO_DIR/initrd.img-$NEW_VERSION" ]; then
        echo "  initrd=$EFI_PATH/initrd.img-$NEW_VERSION"
    fi
    echo "  root=$ROOT_DEV"
    echo "  append=\"$APPEND\""

    if [ -n "$PREV_VERSION" ] && [ -f "$ELILO_DIR/vmlinuz-$PREV_VERSION" ]; then
        echo ""
        echo "image=$EFI_PATH/vmlinuz-$PREV_VERSION"
        echo "  label=linux-old"
        if [ -f "$ELILO_DIR/initrd.img-$PREV_VERSION" ]; then
            echo "  initrd=$EFI_PATH/initrd.img-$PREV_VERSION"
        fi
        echo "  root=$ROOT_DEV"
        echo "  append=\"$APPEND\""
    fi
} > "$CONF_TMP"

mv "$CONF_TMP" "$ELILO_CONF"
echo "update-elilo: wrote $ELILO_CONF (default: linux = $NEW_VERSION)"

# ── Remove kernels older than the previous one ───────────────────────────────

# Keep only the two highest VERSIONS on the ESP (current + previous);
# remove everything below, regardless of mtime.
kernel_versions "$ELILO_DIR" \
    | tail -n +3 \
    | while read -r OLD_VERSION; do
        [ -n "$OLD_VERSION" ] || continue
        echo "update-elilo: removing old kernel $OLD_VERSION from ESP"
        rm -f "$ELILO_DIR/vmlinuz-$OLD_VERSION"
        rm -f "$ELILO_DIR/initrd.img-$OLD_VERSION"
    done
